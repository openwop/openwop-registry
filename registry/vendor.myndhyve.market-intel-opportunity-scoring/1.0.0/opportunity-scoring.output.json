{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.market-intel-opportunity-scoring/1.0.0/opportunity-scoring.output.json",
  "title": "MarketIntelOpportunityScoringOutput",
  "type": "object",
  "required": ["rankedCommunities", "rankedAngles", "insights", "methodology", "warnings", "communityCount", "angleCount", "success"],
  "properties": {
    "rankedCommunities": {
      "type": "array",
      "description": "Sorted by score.total descending.",
      "items": {
        "type": "object",
        "required": ["community", "platform", "score", "rationale", "themes", "focusAreas", "risks"],
        "properties": {
          "community": { "type": "string" },
          "platform": { "type": "string", "enum": ["reddit", "hn", "stackexchange", "forum", "reviews", "other"] },
          "score": { "$ref": "#/$defs/scoreBreakdown" },
          "rationale": { "type": "string" },
          "themes": { "type": "array", "items": { "type": "string" } },
          "focusAreas": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "rankedAngles": {
      "type": "array",
      "description": "Sorted by priority ascending (1 = highest).",
      "items": {
        "type": "object",
        "required": ["angleId", "angleName", "segment", "corePain", "promise", "score", "evidence", "rationale", "communities", "priority"],
        "properties": {
          "angleId": { "type": "string" },
          "angleName": { "type": "string" },
          "segment": { "type": "string", "enum": ["ready_now", "researching", "problem_aware", "unaware"] },
          "corePain": { "type": "string" },
          "promise": { "type": "string" },
          "score": { "$ref": "#/$defs/scoreBreakdown" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "rationale": { "type": "string" },
          "communities": { "type": "array", "items": { "type": "string" } },
          "priority": { "type": "integer", "minimum": 1, "maximum": 10 }
        },
        "additionalProperties": true
      }
    },
    "insights": {
      "type": "object",
      "required": ["topOpportunity", "marketGaps", "competitiveAdvantages", "recommendations"],
      "properties": {
        "topOpportunity": { "type": "string" },
        "marketGaps": { "type": "array", "items": { "type": "string" } },
        "competitiveAdvantages": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "methodology": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "communityCount": { "type": "integer", "minimum": 0 },
    "angleCount": { "type": "integer", "minimum": 0 },
    "model": { "type": "string" },
    "usage": {
      "type": "object",
      "properties": {
        "promptTokens": { "type": "integer" },
        "completionTokens": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "success": { "type": "boolean" }
  },
  "$defs": {
    "scoreBreakdown": {
      "type": "object",
      "required": ["volume", "intensity", "commercialIntent", "clarity", "uniqueness", "total"],
      "properties": {
        "volume": { "type": "number", "minimum": 1, "maximum": 10 },
        "intensity": { "type": "number", "minimum": 1, "maximum": 10 },
        "commercialIntent": { "type": "number", "minimum": 1, "maximum": 10 },
        "clarity": { "type": "number", "minimum": 1, "maximum": 10 },
        "uniqueness": { "type": "number", "minimum": 1, "maximum": 10 },
        "total": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
