{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.flow/1.0.0/aggregate-text.config.json",
  "title": "AggregateTextConfig",
  "type": "object",
  "properties": {
    "path": {
      "type": "string",
      "description": "Optional path to value when template is absent."
    },
    "template": {
      "type": "string",
      "description": "Mustache-style template applied per item."
    },
    "separator": {
      "type": "string",
      "default": ""
    }
  },
  "additionalProperties": false
}
