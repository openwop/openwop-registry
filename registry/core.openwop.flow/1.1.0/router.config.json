{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.flow/1.0.0/router.config.json",
  "title": "RouterConfig",
  "type": "object",
  "required": [
    "routes"
  ],
  "properties": {
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Route",
        "type": "object",
        "required": [
          "label"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "predicate": {
            "type": "object",
            "required": [
              "path",
              "op"
            ],
            "properties": {
              "path": {
                "type": "string",
                "description": "Dot-notation path into the input value."
              },
              "op": {
                "type": "string",
                "enum": [
                  "eq",
                  "neq",
                  "lt",
                  "lte",
                  "gt",
                  "gte",
                  "in",
                  "contains",
                  "starts-with",
                  "ends-with",
                  "regex",
                  "exists",
                  "not-exists",
                  "truthy",
                  "falsy"
                ]
              },
              "value": {
                "description": "Comparison target. Omitted for `exists`/`not-exists`/`truthy`/`falsy`."
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "first-match",
        "all-match"
      ],
      "default": "first-match"
    },
    "defaultLabel": {
      "type": "string",
      "description": "Label emitted when no route matched."
    }
  },
  "additionalProperties": false
}
