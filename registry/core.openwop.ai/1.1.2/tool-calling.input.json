{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
          "content": { "type": "string" }
        },
        "required": ["role", "content"],
        "additionalProperties": true
      }
    }
  },
  "required": ["messages"],
  "additionalProperties": true
}
