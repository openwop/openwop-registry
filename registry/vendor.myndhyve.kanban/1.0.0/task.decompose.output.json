{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.kanban/1.0.0/task.decompose.output.json",
  "title": "TaskDecomposeOutput",
  "type": "object",
  "required": ["taskId", "subtasks"],
  "properties": {
    "taskId": { "type": "string" },
    "subtasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "estimateHours": { "type": "number", "minimum": 0 },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Sibling-subtask indices (`'subtask-0'`, `'subtask-1'`...) this subtask depends on. Resolved relative to the subtasks array order."
          },
          "subtaskId": { "type": "string", "description": "Present only when config.createOnBoard=true." }
        },
        "additionalProperties": true
      }
    },
    "criticalPath": { "type": "array", "items": { "type": "string" }, "description": "Subtask indices on the critical path (when dependencies present)." },
    "usage": {
      "type": "object",
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
