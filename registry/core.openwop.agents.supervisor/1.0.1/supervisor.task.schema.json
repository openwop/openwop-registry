{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.supervisor/1.0.0/supervisor.task.schema.json",
  "title": "SupervisorTask",
  "type": "object",
  "required": ["goal", "subagents"],
  "properties": {
    "goal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000
    },
    "subagents": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["agentId", "persona", "modelClass"],
        "properties": {
          "agentId": { "type": "string", "minLength": 3 },
          "persona": { "type": "string", "minLength": 1 },
          "modelClass": {
            "type": "string",
            "enum": ["reasoning", "writing", "coding", "research", "classification", "general"]
          },
          "description": { "type": "string", "maxLength": 500 }
        },
        "additionalProperties": false
      }
    },
    "maxRounds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16,
      "default": 4
    },
    "context": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
