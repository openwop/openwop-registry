{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.ads-metrics-import/1.0.0/metrics-import.input.json",
  "title": "AdsMetricsImportInput",
  "type": "object",
  "required": ["platformAdIds"],
  "properties": {
    "snapshots": {
      "type": "array",
      "description": "Caller-supplied metric snapshots. From a platform-fetch node OR persistent metrics store. Empty array → zero-valued aggregation + warning.",
      "items": {
        "type": "object",
        "required": ["entityId", "platform", "dateRange"],
        "properties": {
          "entityId": { "type": "string", "minLength": 1 },
          "entityType": { "type": "string", "enum": ["campaign", "ad", "variant"] },
          "platform": { "type": "string", "minLength": 1 },
          "dateRange": {
            "type": "object",
            "required": ["start", "end"],
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            },
            "additionalProperties": true
          },
          "impressions": { "type": "number", "minimum": 0 },
          "clicks": { "type": "number", "minimum": 0 },
          "ctr": { "type": "number", "minimum": 0 },
          "spend": { "type": "number", "minimum": 0 },
          "cpc": { "type": "number", "minimum": 0 },
          "cpm": { "type": "number", "minimum": 0 },
          "conversions": { "type": "number", "minimum": 0 },
          "conversionRate": { "type": "number", "minimum": 0 },
          "costPerConversion": { "type": "number", "minimum": 0 },
          "conversionValue": { "type": "number", "minimum": 0 },
          "roas": { "type": "number", "minimum": 0 },
          "reach": { "type": ["number", "null"] },
          "frequency": { "type": ["number", "null"] },
          "videoViews": { "type": ["number", "null"] },
          "videoCompletions": { "type": ["number", "null"] },
          "qualityScore": { "type": ["number", "null"] },
          "relevanceScore": { "type": ["number", "null"] },
          "fetchedAt": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "platformAdIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Required filter — only snapshots whose entityId matches one of these will be aggregated."
    },
    "platform": { "type": "string", "description": "Optional platform filter (meta / google / linkedin / tiktok / reddit / x). When supplied, only snapshots for this platform are included." },
    "dateRange": {
      "type": "object",
      "description": "Optional exact-match filter on snapshot.dateRange. Matches source's cache key shape.",
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
