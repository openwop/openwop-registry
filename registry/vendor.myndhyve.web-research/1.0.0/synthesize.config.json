{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.web-research/1.0.0/synthesize.config.json",
  "title": "SynthesizeConfig",
  "type": "object",
  "required": ["envelopeType", "systemPrompt"],
  "properties": {
    "envelopeType": {
      "type": "string",
      "pattern": "^[a-z][a-zA-Z0-9._-]*\\.[a-z][a-zA-Z0-9._-]*$",
      "description": "Output envelope type (e.g., `research.summary`, `competitor.profile`)."
    },
    "systemPrompt": { "type": "string", "minLength": 1, "description": "Synthesis prompt. Template syntax `{{var}}` substitutes from inputs.variables." },
    "model": { "type": "string" },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2 }
  },
  "additionalProperties": false
}
