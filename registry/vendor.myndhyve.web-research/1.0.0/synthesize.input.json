{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.web-research/1.0.0/synthesize.input.json",
  "title": "SynthesizeInput",
  "type": "object",
  "required": ["citations"],
  "properties": {
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "content"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "content": { "type": "string" }
        },
        "additionalProperties": true
      },
      "description": "Source citations to synthesize. Typically the output of core.webResearch.researchWeb.citations or core.webResearch.fetchUrls.pages."
    },
    "variables": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
