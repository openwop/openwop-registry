{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.triggers/1.1.0/rss.config.json",
  "title": "RssConfig",
  "type": "object",
  "required": [
    "url",
    "intervalSeconds"
  ],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri"
    },
    "intervalSeconds": {
      "type": "integer",
      "minimum": 60,
      "default": 900
    }
  },
  "additionalProperties": false
}
