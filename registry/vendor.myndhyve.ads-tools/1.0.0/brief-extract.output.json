{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.ads-tools/1.0.0/brief-extract.output.json",
  "title": "AdsBriefExtractOutput",
  "type": "object",
  "required": ["brief", "sellingPoints", "suggestedAngles", "success"],
  "properties": {
    "brief": {
      "type": "object",
      "description": "Full AdBrief record — id, contentContext, sellingPoints, targetAudience, tone, goal, angles, constraints, source, createdAt, updatedAt.",
      "additionalProperties": true
    },
    "sellingPoints": { "type": "array", "items": { "type": "string" } },
    "suggestedAngles": { "type": "array", "items": { "type": "string" } },
    "success": { "type": "boolean" }
  },
  "additionalProperties": true
}
