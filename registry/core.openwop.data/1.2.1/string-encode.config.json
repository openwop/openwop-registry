{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.data/1.1.0/string-encode.config.json",
  "title": "StringEncodeConfig",
  "type": "object",
  "required": [
    "to"
  ],
  "properties": {
    "from": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url",
        "ascii"
      ],
      "default": "utf8"
    },
    "to": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url",
        "ascii"
      ]
    }
  },
  "additionalProperties": false
}
