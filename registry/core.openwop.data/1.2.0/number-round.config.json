{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.data/1.1.0/number-round.config.json",
  "title": "NumberRoundConfig",
  "type": "object",
  "properties": {
    "places": {
      "type": "integer",
      "default": 0
    },
    "mode": {
      "type": "string",
      "enum": [
        "half-up",
        "floor",
        "ceil",
        "trunc"
      ],
      "default": "half-up"
    }
  },
  "additionalProperties": false
}
