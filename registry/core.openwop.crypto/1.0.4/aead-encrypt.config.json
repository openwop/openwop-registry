{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.crypto/1.0.3/aead-encrypt.config.json",
  "title": "AeadEncryptConfig",
  "type": "object",
  "properties": {
    "algorithm": {
      "type": "string",
      "enum": [
        "aes-256-gcm",
        "chacha20-poly1305"
      ],
      "default": "aes-256-gcm"
    },
    "keyEncoding": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url"
      ]
    },
    "inputEncoding": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url"
      ]
    },
    "aadEncoding": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url"
      ]
    },
    "outputEncoding": {
      "type": "string",
      "enum": [
        "hex",
        "base64",
        "base64url"
      ]
    }
  },
  "additionalProperties": false
}
