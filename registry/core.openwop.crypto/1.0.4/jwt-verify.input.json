{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.crypto/1.0.3/jwt-verify.input.json",
  "title": "JwtVerifyInput",
  "type": "object",
  "required": [
    "token"
  ],
  "properties": {
    "token": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "jwks": {
      "type": "object",
      "properties": {
        "keys": {
          "type": "array"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
