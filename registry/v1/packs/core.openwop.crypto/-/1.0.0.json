{
  "name": "core.openwop.crypto",
  "version": "1.0.0",
  "description": "Pure cryptographic primitives: hashing, HMAC, AEAD encrypt/decrypt, asymmetric sign/verify, JWT mint/verify, TOTP, x509 parse + chain verify. Built on node:crypto (Node 20+). Zero npm deps. Pure with respect to keys passed in via inputs.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.crypto",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "crypto",
    "hash",
    "hmac",
    "jwt",
    "totp",
    "x509",
    "ed25519"
  ],
  "engines": {
    "openwop": ">=1.0.0 <2.0.0"
  },
  "nodes": [
    {
      "typeId": "core.crypto.hash",
      "version": "1.0.0",
      "label": "Hash",
      "description": "Cryptographic hash. Algorithms: sha-256, sha-384, sha-512, sha-1 (legacy), md5 (legacy), blake2b512. Output as hex or base64.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/hash.config.json",
      "inputSchemaRef": "schemas/hash.input.json",
      "outputSchemaRef": "schemas/hash.output.json"
    },
    {
      "typeId": "core.crypto.hmac-sign",
      "version": "1.0.0",
      "label": "HMAC Sign",
      "description": "HMAC sign with SHA-256/384/512. Key passed as utf8/hex/base64 string. Output as hex or base64.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/hmac-sign.config.json",
      "inputSchemaRef": "schemas/hmac-sign.input.json",
      "outputSchemaRef": "schemas/hmac-sign.output.json"
    },
    {
      "typeId": "core.crypto.hmac-verify",
      "version": "1.0.0",
      "label": "HMAC Verify",
      "description": "Constant-time HMAC verification. Returns { valid: bool }. Rejects length mismatches without leaking timing.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/hmac-verify.config.json",
      "inputSchemaRef": "schemas/hmac-verify.input.json",
      "outputSchemaRef": "schemas/hmac-verify.output.json"
    },
    {
      "typeId": "core.crypto.aead-encrypt",
      "version": "1.0.0",
      "label": "AEAD Encrypt",
      "description": "Authenticated encryption with associated data. Algorithms: aes-256-gcm, chacha20-poly1305. Non-deterministic — emits a fresh random nonce per call.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "side-effectful"
      ],
      "configSchemaRef": "schemas/aead-encrypt.config.json",
      "inputSchemaRef": "schemas/aead-encrypt.input.json",
      "outputSchemaRef": "schemas/aead-encrypt.output.json"
    },
    {
      "typeId": "core.crypto.aead-decrypt",
      "version": "1.0.0",
      "label": "AEAD Decrypt",
      "description": "Authenticated decryption. Rejects tampered ciphertext with `INVALID_AUTH_TAG`.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/aead-decrypt.config.json",
      "inputSchemaRef": "schemas/aead-decrypt.input.json",
      "outputSchemaRef": "schemas/aead-decrypt.output.json"
    },
    {
      "typeId": "core.crypto.sign",
      "version": "1.0.0",
      "label": "Sign",
      "description": "Asymmetric signature. Algorithms: ed25519, rs256, ps256, es256. Private key in PEM.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/sign.config.json",
      "inputSchemaRef": "schemas/sign.input.json",
      "outputSchemaRef": "schemas/sign.output.json"
    },
    {
      "typeId": "core.crypto.verify",
      "version": "1.0.0",
      "label": "Verify",
      "description": "Asymmetric signature verification. Public key in PEM.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/verify.config.json",
      "inputSchemaRef": "schemas/verify.input.json",
      "outputSchemaRef": "schemas/verify.output.json"
    },
    {
      "typeId": "core.crypto.jwt-mint",
      "version": "1.0.0",
      "label": "JWT Mint",
      "description": "Mint a JWT. Algorithms: HS256/384/512, RS256, PS256, ES256, EdDSA. Standard claims (iss, sub, aud, exp, nbf, iat, jti) handled.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/jwt-mint.config.json",
      "inputSchemaRef": "schemas/jwt-mint.input.json",
      "outputSchemaRef": "schemas/jwt-mint.output.json"
    },
    {
      "typeId": "core.crypto.jwt-verify",
      "version": "1.0.0",
      "label": "JWT Verify",
      "description": "Verify a JWT. Checks signature + exp / nbf / iss / aud. JWKS-aware (accepts a JWKS JSON to resolve kid).",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/jwt-verify.config.json",
      "inputSchemaRef": "schemas/jwt-verify.input.json",
      "outputSchemaRef": "schemas/jwt-verify.output.json"
    },
    {
      "typeId": "core.crypto.totp-generate",
      "version": "1.0.0",
      "label": "TOTP Generate",
      "description": "RFC 6238 TOTP code. SHA-1/256/512. 6/8 digit output. Configurable timestep (default 30s).",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/totp-generate.config.json",
      "inputSchemaRef": "schemas/totp-generate.input.json",
      "outputSchemaRef": "schemas/totp-generate.output.json"
    },
    {
      "typeId": "core.crypto.totp-verify",
      "version": "1.0.0",
      "label": "TOTP Verify",
      "description": "Verify a TOTP code. Configurable drift window (default ±1 timestep) for clock skew tolerance.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/totp-verify.config.json",
      "inputSchemaRef": "schemas/totp-verify.input.json",
      "outputSchemaRef": "schemas/totp-verify.output.json"
    },
    {
      "typeId": "core.crypto.x509-parse",
      "version": "1.0.0",
      "label": "x509 Parse",
      "description": "Parse a PEM x509 certificate. Returns issuer, subject, SAN, fingerprint (sha-256), validFrom, validTo, serialNumber.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/x509-parse.config.json",
      "inputSchemaRef": "schemas/x509-parse.input.json",
      "outputSchemaRef": "schemas/x509-parse.output.json"
    },
    {
      "typeId": "core.crypto.x509-verify-chain",
      "version": "1.0.0",
      "label": "x509 Verify Chain",
      "description": "Verify a leaf cert chains to one of N trust-root certs. Checks signature, validity, and basicConstraints CA flag on each intermediate.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/x509-verify-chain.config.json",
      "inputSchemaRef": "schemas/x509-verify-chain.input.json",
      "outputSchemaRef": "schemas/x509-verify-chain.output.json"
    }
  ],
  "runtime": {
    "language": "javascript",
    "format": "esm",
    "entry": "./index.mjs",
    "minRuntimeVersion": "node>=20"
  },
  "signing": {
    "method": "manual",
    "publicKeyRef": "openwop-team-1",
    "signatureRef": "keys/pack.json.sig"
  },
  "integrity": "sha256-rhtNuIwtA1WwpVD3ABwkVhhksEyGK6DWn/dwW85ajLo="
}
