    "array",
    "object",
    "json",
    "csv",
    "datetime",
    "jsonpath",
    "uuid"
  ],
  "engines": {
    "openwop": ">=1.0.0 <2.0.0"
  },
  "nodes": [
    {
      "typeId": "core.openwop.data.string-case",
      "version": "1.0.0",
      "label": "String Case",
      "description": "Transforms input string to upper / lower / title case. Pure, replay-safe, locale-agnostic (uses JavaScript built-in casing — title case is naive: first letter of each whitespace-separated word).",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/string-case.config.json",
      "inputSchemaRef": "schemas/string-case.input.json",
      "outputSchemaRef": "schemas/string-case.output.json"
    },
    {
      "typeId": "core.openwop.data.string-split",
      "version": "1.0.0",
      "label": "String Split",
      "description": "Splits input string on a separator. Pure. Returns an array. Empty separator splits into per-character array.",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/string-split.config.json",
      "inputSchemaRef": "schemas/string-split.input.json",
      "outputSchemaRef": "schemas/string-split.output.json"
    },
    {
      "typeId": "core.openwop.data.array-filter",
      "version": "1.0.0",
      "label": "Array Filter",
      "description": "Filters an array by a simple equality predicate on a path. Pure. Predicate shape: { path: 'dot.notation', equals: <value> }. For richer predicate languages, downstream packs can layer (e.g., JSONPath or JMESPath as a future v1.x extension).",
      "category": "data",
      "role": "pure",
      "capabilities": [
        "cacheable"
      ],
      "configSchemaRef": "schemas/array-filter.config.json",
      "inputSchemaRef": "schemas/array-filter.input.json",
      "outputSchemaRef": "schemas/array-filter.output.json"
    },
    {
      "typeId": "core.openwop.data.array-map",
      "version": "1.0.0",
      "label": "Array Map",
      "description": "Maps an array via a simple template — each element's keys are substituted into a `{{key}}` template. Pure. For richer transformation languages (jq-style, JSONata), downstream packs can layer.",
