{
  "name": "core.openwop.storage",
  "version": "1.0.0",
  "description": "State primitives — kv / table / cache / blob / queue. Each node gated on its specific host capability block (host.kvStorage, host.tableStorage, host.cache, host.blobStorage, host.queue) per RFCs 0015–0019. Pack delegates to ctx.storage.* host surface. Zero npm deps.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.storage",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "storage",
    "kv",
    "table",
    "cache",
    "blob",
    "queue"
  ],
  "engines": {
    "openwop": ">=1.0.0 <2.0.0"
  },
  "runtime": {
    "language": "javascript",
    "format": "esm",
    "entry": "./index.mjs",
    "minRuntimeVersion": "node>=20"
  },
  "nodes": [
    {
      "typeId": "core.storage.kv-get",
      "version": "1.0.0",
      "label": "KV Get",
      "description": "Read a key from host.kvStorage. Returns { value, found, ttlRemainingMs }.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/kv-get.config.json",
      "inputSchemaRef": "schemas/kv-get.input.json",
      "outputSchemaRef": "schemas/kv-get.output.json"
    },
