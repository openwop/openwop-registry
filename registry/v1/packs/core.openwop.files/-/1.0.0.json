      "version": "1.0.0",
      "label": "File Stat",
      "description": "fstat — returns size, mtime, isDirectory.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/stat.config.json",
      "inputSchemaRef": "schemas/stat.input.json",
      "outputSchemaRef": "schemas/stat.output.json"
    },
    {
      "typeId": "core.files.list",
      "version": "1.0.0",
      "label": "File List",
      "description": "List a directory.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/list.config.json",
      "inputSchemaRef": "schemas/list.input.json",
      "outputSchemaRef": "schemas/list.output.json"
    },
