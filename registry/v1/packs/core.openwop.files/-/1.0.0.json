{
  "name": "core.openwop.files",
  "version": "1.0.0",
  "description": "File + binary primitives — fs CRUD, base64, mime detection, image / PDF / archive processing, FTP / SFTP / SSH. Capability-gated on host.fs (RFC 0014). Hosts MUST enforce sandbox root + path-traversal protection.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.files",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "files",
    "fs",
    "image",
    "pdf",
    "archive",
    "ftp"
  ],
  "engines": {
    "openwop": ">=1.0.0 <2.0.0"
  },
  "peerDependencies": {
    "fs": "supported"
  },
  "runtime": {
    "language": "javascript",
    "format": "esm",
    "entry": "./index.mjs",
    "minRuntimeVersion": "node>=20"
  },
  "nodes": [
    {
      "typeId": "core.files.read",
      "version": "1.0.0",
      "label": "File Read",
      "description": "Read a file from host.fs (returns base64). Host enforces sandbox + path traversal.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/read.config.json",
      "inputSchemaRef": "schemas/read.input.json",
      "outputSchemaRef": "schemas/read.output.json"
    },
    {
      "typeId": "core.files.write",
      "version": "1.0.0",
      "label": "File Write",
      "description": "Write a file. Optional create-only mode.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/write.config.json",
      "inputSchemaRef": "schemas/write.input.json",
      "outputSchemaRef": "schemas/write.output.json"
    },
    {
      "typeId": "core.files.delete",
      "version": "1.0.0",
      "label": "File Delete",
      "description": "Delete a file. Idempotent.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/delete.config.json",
