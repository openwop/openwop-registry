{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.git-author/1.0.0/git-author.return.schema.json",
  "title": "GitAuthorReturn",
  "type": "object",
  "required": [
    "output",
    "shape"
  ],
  "properties": {
    "output": {
      "type": "string",
      "minLength": 1
    },
    "shape": {
      "type": "string",
      "enum": [
        "commit-message",
        "pr-title",
        "pr-body",
        "release-notes",
        "changelog-entry"
      ]
    },
    "conventionalCommitsType": {
      "type": "string",
      "enum": [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    },
    "stoppedReason": {
      "type": "string",
      "enum": [
        "completed",
        "refused",
        "invalid_input"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
