{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.web-search/1.0.0/search.output.json",
  "title": "WebSearchOutput",
  "type": "object",
  "required": ["results", "engine", "query"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "snippet": { "type": "string", "description": "Result snippet." },
          "rank": { "type": "integer", "minimum": 1, "description": "1-based result rank." }
        },
        "additionalProperties": true
      }
    },
    "engine": { "type": "string", "description": "Engine that served the query (echoes config.engine; may differ when the host falls back, or be `stub` in the demo)." },
    "query": { "type": "string", "description": "Echo of the query." },
    "totalResults": { "type": "integer", "minimum": 0, "description": "Engine-reported total matches (NOT limited to maxResults)." },
    "stub": {
      "type": "boolean",
      "description": "True when the host does not advertise `host.webSearch` and the node returned a deterministic fixture instead of a live search. Absent / false for real results."
    }
  },
  "additionalProperties": false
}
