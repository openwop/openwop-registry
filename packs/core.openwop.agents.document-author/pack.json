{
  "name": "core.openwop.agents.document-author",
  "version": "1.0.0",
  "description": "Office-document authoring agent — produces PDF / Word / Excel / PowerPoint deliverables from briefs. Pure-agent pack.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.document-author",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "documents",
    "pdf",
    "office",
    "skill"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.document-author.default",
      "persona": "Document Author",
      "label": "Document Author Agent",
      "description": "Authors PDF / Word / Excel / PowerPoint documents from natural-language briefs. Plans structure, writes content, invokes core.openwop.files PDF/archive primitives to materialize the deliverable. Mirrors Anthropic's top official Office-document skills (PowerPoint/Excel/Word/PDF).",
      "modelClass": "writing",
      "systemPromptRef": "prompts/document-author.md",
      "toolAllowlist": [
        "openwop:core.files.write",
        "openwop:core.files.read",
        "openwop:core.files.pdf-extract-text",
        "openwop:core.files.pdf-split",
        "openwop:core.files.pdf-merge",
        "openwop:core.files.archive-create"
      ],
      "memoryShape": {
        "scratchpad": true,
        "conversation": false,
        "longTerm": false
      },
      "handoff": {
        "taskSchemaRef": "schemas/document-author.task.schema.json",
        "returnSchemaRef": "schemas/document-author.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.7
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
