{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.document-author/1.0.0/document-author.return.schema.json",
  "title": "DocumentAuthorReturn",
  "type": "object",
  "required": [
    "outputPath",
    "format",
    "wordCount",
    "summary"
  ],
  "properties": {
    "outputPath": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": [
        "pdf",
        "docx",
        "xlsx",
        "pptx",
        "md"
      ]
    },
    "pageCount": {
      "type": "integer",
      "minimum": 0
    },
    "wordCount": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "stoppedReason": {
      "type": "string",
      "enum": [
        "completed",
        "refused",
        "invalid_input"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
