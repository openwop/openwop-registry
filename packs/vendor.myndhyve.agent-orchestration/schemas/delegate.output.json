{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.agent-orchestration/1.0.0/delegate.output.json",
  "title": "AgentDelegateOutput",
  "type": "object",
  "required": ["selectedAgentInstanceId", "confidence"],
  "properties": {
    "selectedAgentInstanceId": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Router confidence in the selection." },
    "rationale": { "type": "string", "description": "Free-form explanation of why this candidate was chosen." },
    "escalated": { "type": "boolean", "description": "true when the selection was approved by a human after escalation (confidence < threshold)." },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agentInstanceId": { "type": "string" },
          "score": { "type": "number" }
        }
      }
    }
  },
  "additionalProperties": false
}
