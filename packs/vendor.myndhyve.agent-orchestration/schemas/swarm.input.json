{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.agent-orchestration/1.0.0/swarm.input.json",
  "title": "AgentSwarmInput",
  "type": "object",
  "required": ["task"],
  "properties": {
    "task": { "type": "string", "minLength": 1 },
    "taskData": { "type": "object", "additionalProperties": true },
    "perAgentTask": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional per-agent task overrides keyed by agentInstanceId. When unset, all agents get the same task."
    }
  },
  "additionalProperties": false
}
