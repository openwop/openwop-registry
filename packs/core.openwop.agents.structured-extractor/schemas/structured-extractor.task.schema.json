{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.structured-extractor/1.0.0/structured-extractor.task.schema.json",
  "title": "StructuredExtractorTask",
  "type": "object",
  "required": [
    "input",
    "outputSchema"
  ],
  "properties": {
    "input": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200000
    },
    "outputSchema": {
      "type": "object",
      "description": "Inline JSON Schema 2020-12 document describing the desired output shape. The host validates extracted output against this schema before persistence.",
      "additionalProperties": true
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$",
      "default": "en"
    },
    "maxFixAttempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 3
    }
  },
  "additionalProperties": false
}
