{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.support-resolver/1.0.0/support-resolver.task.schema.json",
  "title": "SupportResolverTask",
  "type": "object",
  "required": [
    "ticket",
    "knowledgeSourceIds"
  ],
  "properties": {
    "ticket": {
      "type": "object",
      "required": [
        "subject",
        "body"
      ],
      "properties": {
        "subject": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50000
        }
      },
      "additionalProperties": false
    },
    "knowledgeSourceIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "escalationContext": {
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
