{
  "name": "core.openwop.agents.support-resolver",
  "version": "1.0.0",
  "description": "Customer support resolver agent. KB-grounded answers with explicit citation, escalation handoff on low confidence. Pure-agent pack.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.support-resolver",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "support",
    "resolver",
    "rag",
    "vertical"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported",
    "openwop.agents.memoryBackends": ">=longTerm"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.support-resolver.default",
      "persona": "Support Resolver",
      "label": "Support Resolver Agent",
      "description": "Resolves a triaged support ticket by retrieving from the knowledge base, drafting a grounded answer with citations, and escalating to a human when confidence falls below threshold. Persists resolution patterns to long-term memory.",
      "modelClass": "writing",
      "systemPromptRef": "prompts/support-resolver.md",
      "toolAllowlist": [
        "openwop:core.rag.retriever-basic",
        "openwop:core.rag.retriever-contextual-compression"
      ],
      "memoryShape": {
        "scratchpad": true,
        "conversation": true,
        "longTerm": true
      },
      "handoff": {
        "taskSchemaRef": "schemas/support-resolver.task.schema.json",
        "returnSchemaRef": "schemas/support-resolver.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.75
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
