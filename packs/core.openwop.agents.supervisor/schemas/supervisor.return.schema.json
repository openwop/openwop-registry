{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openwop.dev/packs/core.openwop.agents.supervisor/supervisor.return.schema.json",
  "title": "SupervisorReturn",
  "type": "object",
  "required": ["answer", "dispatchedSubagents", "stoppedReason"],
  "properties": {
    "answer": { "type": "string", "minLength": 1 },
    "dispatchedSubagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "subtask", "outcome"],
        "properties": {
          "agentId": { "type": "string" },
          "subtask": { "type": "string", "maxLength": 2000 },
          "outcome": {
            "type": "string",
            "enum": ["completed", "failed", "low_confidence", "skipped"]
          },
          "resultSummary": { "type": "string", "maxLength": 1000 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "stoppedReason": {
      "type": "string",
      "enum": ["completed", "max_rounds", "refused", "subagent_unavailable"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
