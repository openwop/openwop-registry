{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.ads-studio-core/1.0.0/brief-build.output.json",
  "title": "AdsBriefBuildOutput",
  "type": "object",
  "properties": {
    "brief": {
      "description": "The constructed AdBrief. Null when input validation failed.",
      "oneOf": [{ "type": "object", "additionalProperties": true }, { "type": "null" }]
    },
    "validationIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "message"],
        "properties": {
          "field": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning"] },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      },
      "description": "Validation issues from validateBrief. Empty when config.validateOutput=false."
    }
  },
  "additionalProperties": true
}
