{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.sales-coach/1.0.0/sales-coach.return.schema.json",
  "title": "SalesCoachReturn",
  "type": "object",
  "required": [
    "dimensionScores",
    "coachingMoments",
    "recommendations"
  ],
  "properties": {
    "dimensionScores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "score",
          "rationale"
        ],
        "properties": {
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "additionalProperties": false
      }
    },
    "coachingMoments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "quote",
          "why"
        ],
        "properties": {
          "quote": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "dimension": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "developmentArc": {
      "type": "string",
      "enum": [
        "improving",
        "steady",
        "regressing",
        "insufficient_history"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
