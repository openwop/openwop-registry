{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.market-intel-discovery/1.0.0/ai-discovery.config.json",
  "title": "MarketIntelAiDiscoveryConfig",
  "type": "object",
  "properties": {
    "provider": { "type": "string", "description": "AI provider override (anthropic / openai / google). Host default routes when omitted." },
    "model": { "type": "string", "description": "Model id override." },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2, "description": "Defaults to 0.3 — discovery values precision (real communities/URLs) over creative variation." },
    "maxTokens": { "type": "integer", "minimum": 256, "description": "Defaults to 2048." }
  },
  "additionalProperties": true
}
