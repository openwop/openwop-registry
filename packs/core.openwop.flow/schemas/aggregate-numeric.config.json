{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.flow/1.0.0/aggregate-numeric.config.json",
  "title": "AggregateNumericConfig",
  "type": "object",
  "required": [
    "op",
    "path"
  ],
  "properties": {
    "op": {
      "type": "string",
      "enum": [
        "sum",
        "count",
        "avg",
        "min",
        "max"
      ]
    },
    "path": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
