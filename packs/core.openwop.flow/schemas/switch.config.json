{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.flow/1.1.0/switch.config.json",
  "title": "SwitchConfig",
  "type": "object",
  "required": [
    "cases"
  ],
  "properties": {
    "cases": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Map of case key → output label."
    },
    "default": {
      "type": "string",
      "description": "Label when no case matches."
    }
  },
  "additionalProperties": false
}
