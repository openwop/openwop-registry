{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.flow/1.1.0/repeater.config.json",
  "title": "RepeaterConfig",
  "type": "object",
  "required": [
    "count"
  ],
  "properties": {
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "start": {
      "type": "number",
      "default": 0
    },
    "step": {
      "type": "number",
      "default": 1
    }
  },
  "additionalProperties": false
}
