{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.devops-crew/1.0.0/verifier.task.schema.json",
  "title": "DevOpsVerifierTask",
  "type": "object",
  "required": ["stepId", "postChecks"],
  "properties": {
    "stepId": { "type": "string" },
    "postChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "spec"],
        "properties": {
          "kind": { "type": "string", "enum": ["fs-exists", "fs-contains", "http-status", "http-body-matches"] },
          "spec": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
