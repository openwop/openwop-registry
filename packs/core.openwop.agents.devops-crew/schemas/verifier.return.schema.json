{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.devops-crew/1.0.0/verifier.return.schema.json",
  "title": "DevOpsVerifierReturn",
  "type": "object",
  "required": ["stepId", "checks", "overallResult"],
  "properties": {
    "stepId": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "result"],
        "properties": {
          "kind": { "type": "string" },
          "spec": { "type": "object", "additionalProperties": true },
          "result": { "type": "string", "enum": ["pass", "fail", "error", "check_kind_unsupported"] },
          "evidence": { "type": "string", "maxLength": 2000 }
        },
        "additionalProperties": false
      }
    },
    "overallResult": { "type": "string", "enum": ["pass", "fail"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
