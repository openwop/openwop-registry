{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.devops-crew/1.0.0/planner.return.schema.json",
  "title": "DevOpsPlannerReturn",
  "type": "object",
  "required": ["plan", "stepsCompleted", "haltReason"],
  "properties": {
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "action"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string", "minLength": 1 },
          "preCheck": { "type": "object", "additionalProperties": true },
          "action": {
            "type": "object",
            "required": ["tool", "arguments"],
            "properties": {
              "tool": { "type": "string", "minLength": 1 },
              "arguments": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": false
          },
          "postCheck": { "type": "object", "additionalProperties": true },
          "requiresHumanApproval": { "type": "boolean", "default": false },
          "rollback": { "type": ["object", "null"], "additionalProperties": true }
        },
        "additionalProperties": false
      }
    },
    "stepsCompleted": { "type": "integer", "minimum": 0 },
    "haltReason": {
      "type": "string",
      "enum": ["completed", "step_failed", "verification_failed", "approval_pending", "refused"]
    },
    "currentStepIndex": { "type": "integer", "minimum": 0 },
    "rollbacksApplied": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
