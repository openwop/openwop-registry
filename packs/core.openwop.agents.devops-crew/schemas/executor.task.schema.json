{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.devops-crew/1.0.0/executor.task.schema.json",
  "title": "DevOpsExecutorTask",
  "type": "object",
  "required": ["step"],
  "properties": {
    "step": {
      "type": "object",
      "required": ["id", "action"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "preCheck": { "type": "object", "additionalProperties": true },
        "action": {
          "type": "object",
          "required": ["tool", "arguments"],
          "properties": {
            "tool": { "type": "string" },
            "arguments": { "type": "object", "additionalProperties": true }
          },
          "additionalProperties": false
        },
        "requiresHumanApproval": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "approvalToken": { "type": "string" }
  },
  "additionalProperties": false
}
