{
  "name": "core.openwop.workflows.lighthouse",
  "version": "1.0.0",
  "kind": "workflow-chain",
  "description": "Real-work workflow pack (RFC 0013, ADR 0149 / ADR 0155). The five zero-config 'lighthouse' workflows from the ADR 0149 catalog — Lead Triage, Account Brief, Renewal & Churn-Risk Digest, RFP Response, and Post-Meeting Follow-up. Authored over the feature node packs (feature.crm/kb/analytics) plus core.ai.chatCompletion, core.chat.approvalGate, and core.openwop.integration.*; every external send is gated by a human approval and all tenant-specific values are run parameters (replay-deterministic). Resolves fully on hosts that ship the feature packs (e.g. the OpenWOP reference app); on other hosts the unmet node types surface as a connect/install prompt rather than failing. Published under core.openwop.workflows.* (openwop-team signing key); the registry adds `signing` at publish time.",
  "author": "openwop",
  "license": "Apache-2.0",
  "engines": {
    "openwop": ">=1.0.0"
  },
  "chains": [
    {
      "chainId": "lighthouse.lead-triage",
      "version": "1.0.0",
      "label": "Inbound Lead Triage & Routing",
      "description": "Enrich and score an inbound lead, draft a first-touch reply, gate it for review, then send and log it. Real CRM data via feature.crm; every send behind a human approval.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [],
        "properties": {
          "firstTouchTone": {
            "type": "string",
            "default": "friendly, concise, and helpful",
            "description": "Tone for the drafted first-touch reply."
          }
        }
      },
      "capabilities": [
        "side-effectful"
      ],
      "dag": {
        "nodes": [
          {
            "id": "triage",
            "typeId": "feature.crm.nodes.triage-enriched",
            "name": "Enrich & score lead",
            "position": {
              "x": 0,
              "y": 0
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "draft",
            "typeId": "core.ai.chatCompletion",
            "name": "Draft first-touch reply",
            "position": {
              "x": 260,
              "y": 0
            },
            "config": {
              "systemPrompt": "You are a sales development rep. Using the enriched, scored lead, draft a {{params.firstTouchTone}} first-touch reply tailored to the lead's context and likely intent. Keep it short and specific."
            },
            "inputs": {}
          },
          {
            "id": "approve",
            "typeId": "core.chat.approvalGate",
            "name": "Approve before send",
            "position": {
              "x": 520,
              "y": 0
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "send",
            "typeId": "core.openwop.integration.email-send",
            "name": "Send first-touch email",
            "position": {
              "x": 780,
              "y": 0
            },
            "config": {},
            "inputs": {}
          }
        ],
        "edges": [
          {
            "from": "triage",
            "to": "draft"
          },
          {
            "from": "draft",
            "to": "approve"
          },
          {
            "from": "approve",
            "to": "send"
          }
        ]
      },
      "outputs": {
        "reply": {
          "type": "string",
          "description": "The approved, sent first-touch reply."
        }
      }
    },
    {
      "chainId": "lighthouse.account-brief",
      "version": "1.0.0",
      "label": "Account Brief & Next-Step Draft",
      "description": "Pull a company profile and its deals, synthesize an account brief with recommended next steps and a draft outreach, gate it, then notify the owner. Real CRM data; advisory send behind approval.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "companyId"
        ],
        "properties": {
          "companyId": {
            "type": "string",
            "description": "The CRM company id to brief."
          }
        }
      },
      "capabilities": [
        "side-effectful"
      ],
      "dag": {
        "nodes": [
          {
            "id": "company",
            "typeId": "feature.crm.nodes.get-company",
            "name": "Get company",
            "position": {
              "x": 0,
              "y": 0
            },
            "config": {
              "companyId": "{{params.companyId}}"
            },
            "inputs": {}
          },
          {
            "id": "deals",
            "typeId": "feature.crm.nodes.list-deals",
            "name": "List deals",
            "position": {
              "x": 0,
              "y": 160
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "brief",
            "typeId": "core.ai.chatCompletion",
            "name": "Write brief + next steps",
            "position": {
              "x": 300,
              "y": 80
            },
            "config": {
              "systemPrompt": "You are a sales strategist. Using the company profile and its deals, write a concise account brief for company {{params.companyId}}: current state, risks, and 3 recommended next steps, plus a short draft outreach the owner can send."
            },
            "inputs": {}
          },
          {
            "id": "approve",
            "typeId": "core.chat.approvalGate",
            "name": "Review brief",
            "position": {
              "x": 560,
              "y": 80
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "notify",
            "typeId": "core.openwop.integration.notification-push",
            "name": "Notify owner",
            "position": {
              "x": 820,
              "y": 80
            },
            "config": {},
            "inputs": {}
          }
        ],
        "edges": [
          {
            "from": "company",
            "to": "brief"
          },
          {
            "from": "deals",
            "to": "brief"
          },
          {
            "from": "brief",
            "to": "approve"
          },
          {
            "from": "approve",
            "to": "notify"
          }
        ]
      },
      "outputs": {
        "brief": {
          "type": "string",
          "description": "The account brief with next steps and a draft outreach."
        }
      }
    },
    {
      "chainId": "lighthouse.renewal-risk",
      "version": "1.0.0",
      "label": "Renewal & Churn-Risk Digest",
      "description": "Combine open deals with usage analytics to score renewal/churn risk, then push an at-risk list with save plays to the CSM. Real CRM + analytics data; advisory, no external send.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [],
        "properties": {
          "segment": {
            "type": "string",
            "default": "all active accounts",
            "description": "Account segment to assess."
          }
        }
      },
      "capabilities": [
        "side-effectful"
      ],
      "dag": {
        "nodes": [
          {
            "id": "deals",
            "typeId": "feature.crm.nodes.list-deals",
            "name": "List open deals",
            "position": {
              "x": 0,
              "y": 0
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "usage",
            "typeId": "feature.analytics.nodes.query",
            "name": "Query usage analytics",
            "position": {
              "x": 0,
              "y": 160
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "score",
            "typeId": "core.ai.chatCompletion",
            "name": "Score risk + save plays",
            "position": {
              "x": 300,
              "y": 80
            },
            "config": {
              "systemPrompt": "You are a customer-success analyst. For {{params.segment}}, combine the open deals with the usage analytics to score renewal/churn risk. Produce a ranked at-risk list with the driver of risk and a concrete save play for each."
            },
            "inputs": {}
          },
          {
            "id": "notify",
            "typeId": "core.openwop.integration.notification-push",
            "name": "Push digest to CSM",
            "position": {
              "x": 560,
              "y": 80
            },
            "config": {},
            "inputs": {}
          }
        ],
        "edges": [
          {
            "from": "deals",
            "to": "score"
          },
          {
            "from": "usage",
            "to": "score"
          },
          {
            "from": "score",
            "to": "notify"
          }
        ]
      },
      "outputs": {
        "digest": {
          "type": "string",
          "description": "The at-risk list with save plays."
        }
      }
    },
    {
      "chainId": "lighthouse.rfp-response",
      "version": "1.0.0",
      "label": "RFP / Proposal Response Assembly",
      "description": "Retrieve answers and past proposals from the knowledge base, draft an RFP response grounded in them, and gate it for SME review. Real KB data via feature.kb RAG.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rfpText"
        ],
        "properties": {
          "rfpText": {
            "type": "string",
            "description": "The RFP requirements text to respond to."
          }
        }
      },
      "capabilities": [
        "side-effectful"
      ],
      "dag": {
        "nodes": [
          {
            "id": "retrieve",
            "typeId": "feature.kb.nodes.rag",
            "name": "Retrieve KB answers",
            "position": {
              "x": 0,
              "y": 0
            },
            "config": {
              "query": "{{params.rfpText}}"
            },
            "inputs": {}
          },
          {
            "id": "draft",
            "typeId": "core.ai.chatCompletion",
            "name": "Draft RFP response",
            "position": {
              "x": 300,
              "y": 0
            },
            "config": {
              "systemPrompt": "You are a proposals writer. Draft a structured RFP response to the requirements below, grounded ONLY in the retrieved knowledge-base answers and past proposals — flag any requirement the KB does not cover. Requirements: {{params.rfpText}}"
            },
            "inputs": {}
          },
          {
            "id": "approve",
            "typeId": "core.chat.approvalGate",
            "name": "SME review",
            "position": {
              "x": 560,
              "y": 0
            },
            "config": {},
            "inputs": {}
          }
        ],
        "edges": [
          {
            "from": "retrieve",
            "to": "draft"
          },
          {
            "from": "draft",
            "to": "approve"
          }
        ]
      },
      "outputs": {
        "response": {
          "type": "string",
          "description": "The SME-reviewed RFP response draft."
        }
      }
    },
    {
      "chainId": "lighthouse.post-meeting",
      "version": "1.0.0",
      "label": "Post-Meeting Follow-up",
      "description": "Extract decisions, action items, and owners from a meeting transcript, draft a follow-up email, gate it, then send. Transcript supplied as a run parameter; every send behind a human approval.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "transcript"
        ],
        "properties": {
          "transcript": {
            "type": "string",
            "description": "The meeting transcript to summarize."
          }
        }
      },
      "capabilities": [
        "side-effectful"
      ],
      "dag": {
        "nodes": [
          {
            "id": "extract",
            "typeId": "core.ai.chatCompletion",
            "name": "Extract actions + draft follow-up",
            "position": {
              "x": 0,
              "y": 0
            },
            "config": {
              "systemPrompt": "You are an executive assistant. From the meeting transcript below, extract the decisions, action items, and their owners, then draft a clear follow-up email summarizing them with due dates where stated. Transcript: {{params.transcript}}"
            },
            "inputs": {}
          },
          {
            "id": "approve",
            "typeId": "core.chat.approvalGate",
            "name": "Approve follow-up",
            "position": {
              "x": 300,
              "y": 0
            },
            "config": {},
            "inputs": {}
          },
          {
            "id": "send",
            "typeId": "core.openwop.integration.email-send",
            "name": "Send follow-up",
            "position": {
              "x": 560,
              "y": 0
            },
            "config": {},
            "inputs": {}
          }
        ],
        "edges": [
          {
            "from": "extract",
            "to": "approve"
          },
          {
            "from": "approve",
            "to": "send"
          }
        ]
      },
      "outputs": {
        "followup": {
          "type": "string",
          "description": "The approved, sent follow-up email."
        }
      }
    }
  ]
}
