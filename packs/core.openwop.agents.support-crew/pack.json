{
  "name": "core.openwop.agents.support-crew",
  "version": "1.0.0",
  "description": "Support 3-agent crew. Triage → Resolver → Escalator. Single dispatch handles the full ticket lifecycle.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.support-crew",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "crew",
    "support",
    "multi-agent",
    "pattern"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported",
    "openwop.agents.memoryBackends": ">=longTerm"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.support-crew.triage",
      "persona": "Triage",
      "label": "Support Triage (Crew)",
      "description": "Identical contract to core.openwop.agents.support-triage. Bundled here for atomic crew dispatch.",
      "modelClass": "classification",
      "systemPromptRef": "prompts/triage.md",
      "toolAllowlist": [],
      "memoryShape": {
        "scratchpad": false,
        "conversation": false,
        "longTerm": false
      },
      "handoff": {
        "taskSchemaRef": "schemas/triage.task.schema.json",
        "returnSchemaRef": "schemas/triage.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.75
      }
    },
    {
      "agentId": "core.openwop.agents.support-crew.resolver",
      "persona": "Resolver",
      "label": "Support Resolver (Crew)",
      "description": "Identical contract to core.openwop.agents.support-resolver. Bundled here so the crew can dispatch end-to-end without external pack lookups.",
      "modelClass": "writing",
      "systemPromptRef": "prompts/resolver.md",
      "toolAllowlist": [
        "openwop:core.rag.retriever-basic",
        "openwop:core.rag.retriever-contextual-compression"
      ],
      "memoryShape": {
        "scratchpad": true,
        "conversation": true,
        "longTerm": true
      },
      "handoff": {
        "taskSchemaRef": "schemas/resolver.task.schema.json",
        "returnSchemaRef": "schemas/resolver.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.75
      }
    },
    {
      "agentId": "core.openwop.agents.support-crew.escalator",
      "persona": "Escalator",
      "label": "Support Escalator",
      "description": "Builds the escalation packet — context summary + classification + suggested specialist — when the Resolver returns escalation. Persists escalation patterns to long-term memory for staffing analytics.",
      "modelClass": "writing",
      "systemPromptRef": "prompts/escalator.md",
      "toolAllowlist": [],
      "memoryShape": {
        "scratchpad": true,
        "conversation": false,
        "longTerm": true
      },
      "handoff": {
        "taskSchemaRef": "schemas/escalator.task.schema.json",
        "returnSchemaRef": "schemas/escalator.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.8
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
