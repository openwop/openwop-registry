{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.support-crew/1.0.0/triage.return.schema.json",
  "title": "SupportCrewTriageReturn",
  "type": "object",
  "required": ["queue", "severity", "priority", "rationale"],
  "properties": {
    "queue": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "priority": { "type": "string", "enum": ["P1", "P2", "P3", "P4"] },
    "skillTags": { "type": "array", "items": { "type": "string" } },
    "rationale": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "suggestedResolverContext": { "type": "string", "maxLength": 500 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
