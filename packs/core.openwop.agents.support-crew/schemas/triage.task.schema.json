{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.support-crew/1.0.0/triage.task.schema.json",
  "title": "SupportCrewTriageTask",
  "type": "object",
  "required": ["subject", "body", "validQueues"],
  "properties": {
    "subject": { "type": "string", "minLength": 1, "maxLength": 500 },
    "body": { "type": "string", "minLength": 1, "maxLength": 50000 },
    "customerSegment": { "type": "string", "enum": ["enterprise", "mid-market", "smb", "free"] },
    "validQueues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "skillVocabulary": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
