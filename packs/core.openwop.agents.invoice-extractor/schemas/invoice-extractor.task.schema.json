{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.invoice-extractor/1.0.0/invoice-extractor.task.schema.json",
  "title": "InvoiceExtractorTask",
  "type": "object",
  "oneOf": [
    {
      "required": [
        "pdfPath"
      ]
    },
    {
      "required": [
        "text"
      ]
    }
  ],
  "properties": {
    "pdfPath": {
      "type": "string",
      "minLength": 1
    },
    "text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500000
    },
    "knownInvoiceNumbers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "maxItems": 10000
    },
    "vendorWatchlist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 1000
    },
    "defaultCurrency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    }
  },
  "additionalProperties": false
}
