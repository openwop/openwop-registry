{
  "name": "core.openwop.agents.invoice-extractor",
  "version": "1.0.0",
  "description": "Invoice extraction agent. OCR-aware structured extraction of vendor, line items, totals, tax, payment terms from PDF or scanned-image invoices. Pure-agent pack.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.invoice-extractor",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "finance",
    "invoice",
    "extraction",
    "vertical"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.invoice-extractor.default",
      "persona": "Invoice Extractor",
      "label": "Invoice Extractor Agent",
      "description": "Extracts structured fields (vendor, line items, totals, tax, payment terms) from invoice PDFs or text. Returns confidence per field and flags anomalies (math doesn't add up, missing fields, suspicious vendor patterns).",
      "modelClass": "classification",
      "systemPromptRef": "prompts/invoice-extractor.md",
      "toolAllowlist": [
        "openwop:core.files.pdf-extract-text",
        "openwop:core.files.read"
      ],
      "memoryShape": {
        "scratchpad": false,
        "conversation": false,
        "longTerm": false
      },
      "handoff": {
        "taskSchemaRef": "schemas/invoice-extractor.task.schema.json",
        "returnSchemaRef": "schemas/invoice-extractor.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.85
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
