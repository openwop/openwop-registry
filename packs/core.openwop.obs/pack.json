{
  "name": "core.openwop.obs",
  "version": "1.0.0",
  "description": "Observability emission primitives. Workflows publish logs / metrics / traces / alerts under the canonical openwop.* OTel namespace. Delegates to ctx.observability when the host advertises it, no-ops gracefully otherwise. Zero npm deps.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.obs",
  "repository": "https://github.com/openwop/openwop",
  "keywords": ["core", "observability", "otel", "logs", "metrics", "traces"],
  "engines": { "openwop": ">=1.0.0 <2.0.0" },
  "nodes": [
    { "typeId": "core.obs.log", "version": "1.0.0", "label": "Log",
      "description": "Emit a structured log entry under openwop.workflow.* — level, message, optional attributes.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/log.config.json", "inputSchemaRef": "schemas/log.input.json", "outputSchemaRef": "schemas/log.output.json" },
    { "typeId": "core.obs.metric-counter", "version": "1.0.0", "label": "Metric — Counter",
      "description": "Increment a counter. Name MUST start with openwop.workflow.* or be auto-prefixed.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/metric-counter.config.json", "inputSchemaRef": "schemas/metric-counter.input.json", "outputSchemaRef": "schemas/metric-counter.output.json" },
    { "typeId": "core.obs.metric-gauge", "version": "1.0.0", "label": "Metric — Gauge",
      "description": "Set a gauge value.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/metric-gauge.config.json", "inputSchemaRef": "schemas/metric-gauge.input.json", "outputSchemaRef": "schemas/metric-gauge.output.json" },
    { "typeId": "core.obs.metric-histogram", "version": "1.0.0", "label": "Metric — Histogram",
      "description": "Record a histogram sample.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/metric-histogram.config.json", "inputSchemaRef": "schemas/metric-histogram.input.json", "outputSchemaRef": "schemas/metric-histogram.output.json" },
    { "typeId": "core.obs.trace-span-start", "version": "1.0.0", "label": "Trace Span Start",
      "description": "Start a child span. Returns a spanHandle the matching end node consumes. Honors propagated context per observability.md.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/trace-span-start.config.json", "inputSchemaRef": "schemas/trace-span-start.input.json", "outputSchemaRef": "schemas/trace-span-start.output.json" },
    { "typeId": "core.obs.trace-span-end", "version": "1.0.0", "label": "Trace Span End",
      "description": "End a span by handle. Optional status + attributes.",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/trace-span-end.config.json", "inputSchemaRef": "schemas/trace-span-end.input.json", "outputSchemaRef": "schemas/trace-span-end.output.json" },
    { "typeId": "core.obs.alert-fire", "version": "1.0.0", "label": "Alert — Fire",
      "description": "Fire a routed alert event. Vendor packs subscribe (Slack/PagerDuty/email).",
      "category": "control", "role": "side-effect", "capabilities": ["side-effectful"],
      "configSchemaRef": "schemas/alert-fire.config.json", "inputSchemaRef": "schemas/alert-fire.input.json", "outputSchemaRef": "schemas/alert-fire.output.json" }
  ],
  "runtime": { "language": "javascript", "format": "esm", "entry": "./index.mjs", "minRuntimeVersion": "node>=20" }
}
