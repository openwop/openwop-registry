{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.doc-writer/1.0.0/doc-writer.return.schema.json",
  "title": "DocWriterReturn",
  "type": "object",
  "required": [
    "document",
    "wordCount"
  ],
  "properties": {
    "document": {
      "type": "string",
      "minLength": 1
    },
    "outputPath": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "relevance": {
            "type": "string",
            "maxLength": 200
          }
        },
        "additionalProperties": false
      }
    },
    "wordCount": {
      "type": "integer",
      "minimum": 0
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
