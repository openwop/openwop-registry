{
  "name": "core.openwop.agents.test-author",
  "version": "1.0.0",
  "description": "Test authoring agent. Generates unit, integration, and e2e tests from source code or specs. Pure-agent pack.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.test-author",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "testing",
    "coding",
    "tdd",
    "skill"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.test-author.default",
      "persona": "Test Author",
      "label": "Test Author Agent",
      "description": "Generates unit, integration, or e2e tests from source code or specs. Framework-aware (Jest/Vitest/Pytest/Go test/Playwright). Reads existing tests to match house style.",
      "modelClass": "coding",
      "systemPromptRef": "prompts/test-author.md",
      "toolAllowlist": [
        "openwop:core.files.write",
        "openwop:core.files.read"
      ],
      "memoryShape": {
        "scratchpad": true,
        "conversation": false,
        "longTerm": false
      },
      "handoff": {
        "taskSchemaRef": "schemas/test-author.task.schema.json",
        "returnSchemaRef": "schemas/test-author.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.7
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
