{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.crypto/1.0.4/x509-verify-chain.output.json",
  "title": "X509VerifyChainOutput",
  "type": "object",
  "required": [
    "valid"
  ],
  "properties": {
    "valid": {
      "type": "boolean"
    },
    "reason": {
      "type": "string"
    },
    "failedAt": {
      "type": "integer"
    },
    "chain": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
