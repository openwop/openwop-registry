{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.crypto/1.0.4/hash.config.json",
  "title": "HashConfig",
  "type": "object",
  "properties": {
    "algorithm": {
      "type": "string",
      "enum": [
        "sha256",
        "sha384",
        "sha512",
        "sha1",
        "md5",
        "blake2b512"
      ],
      "default": "sha256"
    },
    "inputEncoding": {
      "type": "string",
      "enum": [
        "utf8",
        "hex",
        "base64",
        "base64url"
      ]
    },
    "outputEncoding": {
      "type": "string",
      "enum": [
        "hex",
        "base64",
        "base64url"
      ]
    }
  },
  "additionalProperties": false
}
