{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.mcp/1.1.1/server-status.config.json",
  "title": "ServerStatusConfig",
  "type": "object",
  "required": [
    "serverId"
  ],
  "properties": {
    "serverId": {
      "type": "string",
      "minLength": 1
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 30000,
      "default": 5000,
      "description": "Health-check timeout. After this, the server is reported as `available: false` (no exception thrown — workflow authors branch on the boolean)."
    }
  },
  "additionalProperties": false
}
