{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.mcp/1.1.1/set-log-level.input.json",
  "title": "McpSetLogLevelInput",
  "type": "object",
  "required": [
    "level"
  ],
  "properties": {
    "level": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "notice",
        "warning",
        "error",
        "critical",
        "alert",
        "emergency"
      ]
    }
  },
  "additionalProperties": false
}
