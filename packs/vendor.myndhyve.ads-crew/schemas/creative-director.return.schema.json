{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.ads-crew/1.0.0/creative-director.return.schema.json",
  "title": "CreativeDirectorReturn",
  "type": "object",
  "oneOf": [
    {
      "required": [
        "mode",
        "campaignSpec"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "plan",
            "produce",
            "publish",
            "analyze"
          ]
        },
        "campaignSpec": {
          "type": "object",
          "additionalProperties": true
        },
        "assetRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "kind",
              "ref"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "copy",
                  "image",
                  "video"
                ]
              },
              "ref": {
                "type": "string"
              },
              "placement": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "validationResults": {
          "type": "object",
          "properties": {
            "passed": {
              "type": "boolean"
            },
            "blockingFailures": {
              "type": "array",
              "items": {
                "additionalProperties": true
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": false
        },
        "publishedIds": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "campaignId": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "live",
                  "pending",
                  "failed",
                  "rolled_back"
                ]
              },
              "error": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "synthesizedInsights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    {
      "required": [
        "stoppedReason"
      ],
      "properties": {
        "stoppedReason": {
          "type": "string",
          "enum": [
            "refused",
            "validation_blocked",
            "invalid_input",
            "publish_failed"
          ]
        },
        "detail": {
          "type": "string"
        },
        "violations": {
          "type": "array",
          "items": {
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  ]
}
