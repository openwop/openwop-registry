{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.audit-summarizer/1.0.0/audit-summarizer.task.schema.json",
  "title": "AuditSummarizerTask",
  "type": "object",
  "required": [
    "logs",
    "logSchema",
    "periodLabel"
  ],
  "properties": {
    "logs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "logSchema": {
      "type": "object",
      "additionalProperties": true,
      "description": "JSON Schema (or schema-like object) describing the log record shape."
    },
    "periodLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "violationPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "matcher"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "matcher": {
            "type": "string",
            "description": "JSONPath, regex, or plain-text pattern matching log records."
          },
          "severity": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "baselineRef": {
      "type": "string"
    },
    "businessHoursWindow": {
      "type": "object",
      "properties": {
        "tz": {
          "type": "string"
        },
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        },
        "daysOfWeek": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
