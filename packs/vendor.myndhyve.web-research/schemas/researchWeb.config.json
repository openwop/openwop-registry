{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.web-research/1.0.0/researchWeb.config.json",
  "title": "ResearchWebConfig",
  "type": "object",
  "properties": {
    "engine": { "type": "string" },
