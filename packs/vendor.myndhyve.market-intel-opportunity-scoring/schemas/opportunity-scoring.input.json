{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.market-intel-opportunity-scoring/1.0.0/opportunity-scoring.input.json",
  "title": "MarketIntelOpportunityScoringInput",
  "type": "object",
  "required": ["vocRecords", "communities", "icpContext", "productContext"],
  "properties": {
    "vocRecords": {
      "type": "array",
      "minItems": 1,
      "description": "VoC summary records. Top 50 are shown to the AI (prompt-size cap).",
      "items": {
        "type": "object",
        "properties": {
          "tagType": { "type": "string", "enum": ["pain", "desire", "objection", "trigger", "proof_request", "alternative"] },
          "intentStage": { "type": "string", "enum": ["ready_now", "researching", "problem_aware", "unaware"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "community": { "type": "string" },
          "quotePreview": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "communities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "platform": { "type": "string", "enum": ["reddit", "hn", "stackexchange", "forum", "reviews", "other"] },
          "vocCount": { "type": "integer", "minimum": 0 },
          "avgConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "intentDistribution": { "type": "object", "additionalProperties": { "type": "integer" } },
          "tagDistribution": { "type": "object", "additionalProperties": { "type": "integer" } },
          "sampleQuotes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "icpContext": {
      "type": "object",
      "required": ["roles", "industry", "problems", "outcomes"],
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" } },
        "industry": { "type": "string" },
        "problems": { "type": "array", "items": { "type": "string" } },
        "outcomes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "productContext": {
      "type": "object",
      "required": ["name", "category", "differentiators"],
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "differentiators": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "scoringWeights": {
      "type": "object",
      "description": "Override the default weights (0.2 / 0.25 / 0.3 / 0.15 / 0.1). All 5 default when omitted.",
      "properties": {
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "commercialIntent": { "type": "number", "minimum": 0, "maximum": 1 },
        "clarity": { "type": "number", "minimum": 0, "maximum": 1 },
        "uniqueness": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "maxOpportunities": { "type": "integer", "minimum": 1, "description": "Soft target for ranked-* counts (passed to AI). Defaults to 10." }
  },
  "additionalProperties": true
}
