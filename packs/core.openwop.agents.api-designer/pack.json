{
  "name": "core.openwop.agents.api-designer",
  "version": "1.0.0",
  "description": "API design agent. Authors OpenAPI 3.1, AsyncAPI 3.0, and JSON Schema 2020-12 documents from natural-language briefs. Pure-agent pack.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.agents.api-designer",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "agents",
    "api",
    "openapi",
    "asyncapi",
    "json-schema",
    "skill"
  ],
  "engines": {
    "openwop": ">=1.1.0 <2.0.0"
  },
  "peerDependencies": {
    "aiProviders": "supported",
    "host.agentRuntime": "supported"
  },
  "agents": [
    {
      "agentId": "core.openwop.agents.api-designer.default",
      "persona": "API Designer",
      "label": "API Designer Agent",
      "description": "Authors OpenAPI 3.1 / AsyncAPI 3.0 / JSON Schema 2020-12 documents from briefs. Self-validates via openwop:core.data.json-schema-validate. Writes to disk via openwop:core.files.fs-write when outputPath is set.",
      "modelClass": "coding",
      "systemPromptRef": "prompts/api-designer.md",
      "toolAllowlist": [
        "openwop:core.openwop.data.json-schema-validate",
        "openwop:core.files.write",
        "openwop:core.files.read"
      ],
      "memoryShape": {
        "scratchpad": true,
        "conversation": false,
        "longTerm": false
      },
      "handoff": {
        "taskSchemaRef": "schemas/api-designer.task.schema.json",
        "returnSchemaRef": "schemas/api-designer.return.schema.json"
      },
      "confidence": {
        "defaultThreshold": 0.8
      }
    }
  ],
  "runtime": {
    "language": "remote",
    "entry": "pack.json"
  }
}
