{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.frontend-designer/1.0.0/frontend-designer.return.schema.json",
  "title": "FrontendDesignerReturn",
  "type": "object",
  "required": [
    "components",
    "layout",
    "skeletonCode"
  ],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "purpose",
          "props"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[A-Z][A-Za-z0-9]*$"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "props": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "type",
                "required"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                },
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "required": {
                  "type": "boolean"
                },
                "description": {
                  "type": "string",
                  "maxLength": 500
                }
              },
              "additionalProperties": false
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "a11y": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "skeletonCode": {
      "type": "string",
      "minLength": 1
    },
    "outputPath": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
