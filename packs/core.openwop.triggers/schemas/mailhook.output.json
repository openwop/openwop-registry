{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.triggers/1.1.0/mailhook.output.json",
  "title": "MailhookOutput",
  "type": "object",
  "required": [
    "from",
    "subject"
  ],
  "properties": {
    "from": {
      "type": "string"
    },
    "to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subject": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "html": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "headers": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
