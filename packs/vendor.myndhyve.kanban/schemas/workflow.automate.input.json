{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.kanban/1.0.0/workflow.automate.input.json",
  "title": "WorkflowAutomateInput",
  "type": "object",
  "required": ["boardId", "rules"],
  "properties": {
    "boardId": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["trigger", "action"],
        "properties": {
          "trigger": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["column-transition", "due-date-approaching", "label-changed", "assignee-changed"] }
            },
            "additionalProperties": true
          },
          "action": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["assign", "move-column", "set-label", "send-notification", "invoke-workflow"] }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
