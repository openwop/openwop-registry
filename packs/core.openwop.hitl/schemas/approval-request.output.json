{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.hitl/1.0.0/approval-request.output.json",
  "title": "ApprovalRequestOutput",
  "type": "object",
  "required": [
    "decision"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "comment": {
      "type": [
        "string",
        "null"
      ]
    },
    "decidedBy": {
      "type": [
        "string",
        "null"
      ]
    },
    "decidedAt": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
