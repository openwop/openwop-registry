{
  "name": "core.openwop.http",
  "version": "2.0.0",
  "description": "HTTP + general transport pack. v2.0 (RFC 0076 §B): prefers the host-mediated, SSRF-guarded `ctx.http.safeFetch` for all outbound when the host exposes it, falling back to the pack's own `assertPublicUrl` (node:dns) + `globalThis.fetch` otherwise; declares `runtime.requires: [\"net.dns\",\"net.outbound\"]` for the fallback path. v1.0 baseline: core.openwop.http.fetch (retry, backoff, idempotency). v1.1 additions: openapi-call, GraphQL (query/mutation/subscription), SOAP, gRPC (4 streaming variants), SSE consume, WebSocket client, long-poll, upload (multipart + resumable), download stream, pagination decorators (cursor/offset/link-header), rate-limit-aware retry, circuit breaker, idempotency-key generator, webhook signature verifier (Stripe/GitHub/Slack/raw-hmac). Zero npm deps — Node 20+ fetch/undici; transports requiring native libs delegate to host capabilities.",
  "author": "OpenWOP Working Group",
  "license": "Apache-2.0",
  "homepage": "https://openwop.dev/packs/core.openwop.http",
  "repository": "https://github.com/openwop/openwop",
  "keywords": [
    "core",
    "http",
    "fetch",
    "graphql",
    "grpc",
    "sse",
    "websocket",
    "openapi",
    "webhook"
  ],
  "engines": {
    "openwop": ">=1.0.0 <2.0.0"
  },
  "nodes": [
    {
      "typeId": "core.openwop.http.fetch",
      "version": "1.0.0",
      "label": "HTTP Fetch",
      "description": "Issues an HTTP request. Side-effectful (declared via the `side-effectful` capability) so the engine's Layer-2 invocation log caches responses keyed on (runId, nodeId, idempotencyKey) — replays return the cached response without re-issuing the request. Retries 5xx + network errors with exponential backoff; never retries 4xx (client error). Auth headers are the workflow author's concern — pass them through `config.headers` directly, or use the host's templating to inject a resolved credential.",
      "category": "integration",
      "role": "side-effect",
      "capabilities": [
        "cacheable",
        "side-effectful"
      ],
      "configSchemaRef": "schemas/fetch.config.json",
      "inputSchemaRef": "schemas/fetch.input.json",
      "outputSchemaRef": "schemas/fetch.output.json"
    },
