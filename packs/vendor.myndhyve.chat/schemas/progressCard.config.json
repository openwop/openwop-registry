{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.chat/1.0.0/progressCard.config.json",
  "title": "ChatProgressCardConfig",
  "type": "object",
  "required": ["cardId", "stages"],
  "properties": {
    "cardId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Stable card identifier. Subsequent core.chat.updateCard calls reference this same cardId to mutate the same card."
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "description": "Stage definitions for the progress bar."
    },
    "title": { "type": "string", "description": "Optional card title." }
  },
  "additionalProperties": false
}
