{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/vendor.myndhyve.ai/1.0.0/generateFromPrompt.config.json",
  "title": "GenerateFromPromptConfig",
  "type": "object",
  "required": ["systemPrompt", "envelopeType"],
  "properties": {
    "systemPrompt": { "type": "string", "minLength": 1, "description": "Inline system prompt. Template syntax `{{var}}` substitutes from inputs.variables." },
    "envelopeType": {
      "type": "string",
      "pattern": "^[a-z][a-zA-Z0-9._-]*\\.[a-z][a-zA-Z0-9._-]*$",
      "description": "Typed envelope discriminator (e.g., `prd.create`, `theme.create`). The host's envelope normalizer + artifact-sync routes the result based on this."
    },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
    "maxTokens": { "type": "integer", "minimum": 1, "maximum": 100000 }
  },
  "additionalProperties": false
}
