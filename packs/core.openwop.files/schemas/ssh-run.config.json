{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.files/1.0.0/ssh-run.config.json",
  "title": "SshRunConfig",
  "type": "object",
  "required": [
    "host"
  ],
  "properties": {
    "host": {
      "type": "string"
    },
    "port": {
      "type": "integer"
    },
    "user": {
      "type": "string"
    },
    "timeoutMs": {
      "type": "integer"
    }
  },
  "additionalProperties": false
}
