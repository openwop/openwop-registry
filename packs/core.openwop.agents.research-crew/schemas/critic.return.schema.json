{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.research-crew/1.0.0/critic.return.schema.json",
  "title": "ResearchCriticReturn",
  "type": "object",
  "required": ["perSubQuestion", "overallReady"],
  "properties": {
    "perSubQuestion": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subQuestion", "decision", "rationale"],
        "properties": {
          "subQuestion": { "type": "string" },
          "decision": { "type": "string", "enum": ["approve", "re-retrieve", "reject-as-unanswerable"] },
          "rationale": { "type": "string", "minLength": 1, "maxLength": 1000 },
          "weakSources": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "overallReady": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
