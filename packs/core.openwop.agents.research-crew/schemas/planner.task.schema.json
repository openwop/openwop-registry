{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.research-crew/1.0.0/planner.task.schema.json",
  "title": "ResearchPlannerTask",
  "type": "object",
  "required": ["goal", "crewSubagents"],
  "properties": {
    "goal": { "type": "string", "minLength": 1, "maxLength": 5000 },
    "crewSubagents": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["agentId", "persona"],
        "properties": {
          "agentId": { "type": "string", "minLength": 3 },
          "persona": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "maxRounds": { "type": "integer", "minimum": 1, "maximum": 8, "default": 3 }
  },
  "additionalProperties": false
}
