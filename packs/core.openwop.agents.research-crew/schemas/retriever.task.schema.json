{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.research-crew/1.0.0/retriever.task.schema.json",
  "title": "ResearchRetrieverTask",
  "type": "object",
  "required": ["subQuestion"],
  "properties": {
    "subQuestion": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "preferredSources": { "type": "array", "items": { "type": "string" } },
    "maxToolCalls": { "type": "integer", "minimum": 1, "maximum": 20, "default": 5 }
  },
  "additionalProperties": false
}
