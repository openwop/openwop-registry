{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://packs.openwop.dev/core.openwop.agents.research-crew/1.0.0/retriever.return.schema.json",
  "title": "ResearchRetrieverReturn",
  "type": "object",
  "required": ["subQuestion", "evidence", "retrievalAttempts"],
  "properties": {
    "subQuestion": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sourceId", "retrievedAt", "relevance"],
        "properties": {
          "sourceId": { "type": "string", "minLength": 1 },
          "retrievedAt": { "type": "string" },
          "relevance": { "type": "string", "maxLength": 500 },
          "excerpt": { "type": "string", "maxLength": 5000 }
        },
        "additionalProperties": false
      }
    },
    "retrievalAttempts": { "type": "integer", "minimum": 0 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
